{
  "name": "Dispatcharr",
  "cosmos-installer": {
    "form": [
        {
        "name": "TZ",
        "label": "Timezone",
        "initialValue": "Europe/Berlin",
        "type": "text",
        "required": true
        },
        {
        "name": "PUID",
        "label": "Container User ID (PUID)",
        "initialValue": "1001",
        "type": "text",
        "required": true
      },
      {
        "name": "PGID",
        "label": "Container Group ID (PGID)",
        "initialValue": "1001",
        "type": "text",
        "required": true
      },
      {
        "name": "DispatcharrInternalPort",
        "label": "Container Port",
        "initialValue": "9191",
        "type": "text",
        "required": true
      },
      {
        "name": "Network",
        "label": "Docker Network Name",
        "initialValue": "dispatcharr",
        "type": "text",
        "required": true
      },
      {
        "name": "adminOnly",
        "label": "Do you want to make this service admin only?",
        "initialValue": false,
        "type": "checkbox"
      }
    ]
  },
  "minVersion": "0.9.0",
  "services": {
    "{ServiceName}": {
      "image": "ghcr.io/dispatcharr/dispatcharr:latest",
      "container_name": "{ServiceName}",
      "restart": "unless-stopped",
      "hostname": "{ServiceName}",
      "ports": [
        "{Context.DispatcharrPort}:9191"
      ],
      "environment": [
        "DISPATCHARR_ENV=aio",
        "REDIS_HOST=localhost",
        "CELERY_BROKER_URL=redis://localhost:6379/0",
        "DISPATCHARR_LOG_LEVEL=info",
        "TZ={Context.TZ}",
        "PUID={Context.PUID}",
        "PGID={Context.PGID}"
      ],
      "volumes": [
        {
          "source": "{ServiceName}_data",
          "target": "/data",
          "type": "volume"
        }
      ],
      "devices": [
        "/dev/dri:/dev/dri"
      ],
      "routes": [
        {
          "name": "{ServiceName}",
          "description": "Expose {ServiceName} to the web",
          "useHost": true,
          "target": "http://{ServiceName}:9191",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 12000,
          "BlockCommonBots": true,
          "SmartShield": {
            "Enabled": true
          },
          "AuthEnabled": true
          {if Context.adminOnly}
          , "AuthAdmin": true
          {/if}
        }
      ],
      "labels": {
        "cosmos-auto-update": "true",
        "cosmos-icon": "https://veneziaisking.github.io/cosmos-servapps/servapps/dispatcharr/icon.png",
        "cosmos-force-network-secured": "true"
      },
      "networks": {
        "{Context.Network}": {}
      },
      "network_mode": "{Context.Network}"
    }
  },
  "networks": {
    "media-stack": {
      "name": "{Context.Network}",
      "driver": "bridge",
      "attachable": true
    }
  }
}
